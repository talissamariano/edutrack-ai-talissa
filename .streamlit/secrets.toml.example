# Copie este arquivo para .streamlit/secrets.toml e ajuste com as URLs reais.
# Cada api_group do Xano tem seu proprio canonical, por isso configuramos uma
# URL base separada por grupo.
#
# Como obter no Xano: abra o api_group no dashboard e copie a URL base mostrada
# no topo (ex.: https://x8ki-letl-twmt.n7.xano.io/api:<canonical>).
#
# O arquivo .streamlit/secrets.toml NAO deve ser commitado (ja esta no .gitignore).

xano_auth_base_url = "https://EXEMPLO.xano.io/api:AUTH_CANONICAL"
xano_subjects_base_url = "https://EXEMPLO.xano.io/api:SUBJECTS_CANONICAL"
xano_academic_tasks_base_url = "https://EXEMPLO.xano.io/api:TASKS_CANONICAL"
